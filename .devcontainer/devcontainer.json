{
  "name": "Framework Playground",
  "dockerComposeFile": "docker-compose.yml",
  "service": "framework-playground",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "postCreateCommand": "[ -f package.json ] && pnpm install || echo 'No package.json found, skipping pnpm install'",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Angular.ng-template",
        "bradlc.vscode-tailwindcss",
        "nrwl.angular-console"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "forwardPorts": [3001, 3002, 3003],
  "portsAttributes": {
    "3001": { "label": "Framework-playground" },
    "3002": { "label": "Framework-host" },
    "3003": { "label": "Dashboard" }
  }
}
